@model NoDeskGroup1.Models.Employee
@using Microsoft.AspNetCore.Mvc.Rendering

<div class="container py-4">
    <div class="card shadow-sm form-card p-4">
        <h2 class="page-title mb-4 text-center">Create Employee</h2>

        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="FullName" class="form-label fw-semibold"></label>
                <input asp-for="FullName" class="form-control" placeholder="Enter full name" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold"></label>
                <input asp-for="Email" class="form-control" placeholder="Enter email address" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PasswordHash" class="form-label fw-semibold"></label>
                <input asp-for="PasswordHash" type="password" class="form-control" placeholder="Enter password" />
                <span asp-validation-for="PasswordHash" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Role" class="form-label fw-semibold"></label>
                <select asp-for="Role" class="form-select"
                        asp-items="new SelectList((IEnumerable<string>)ViewBag.Roles)">
                    <option value="">-- Select Role --</option>
                </select>
                <span asp-validation-for="Role" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary px-4">Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
