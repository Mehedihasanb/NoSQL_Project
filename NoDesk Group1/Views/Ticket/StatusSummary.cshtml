@model IEnumerable<(string Status, int Count)>

<div class="container py-4">
    <div class="card shadow-sm form-card p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="page-title m-0">Tickets by Status</h2>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to Tickets
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Status</th>
                        <th>Count</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="2" class="text-center py-4 text-muted">
                                No data available.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var x in Model)
                        {
                            <tr>
                                <td>
                                    <span class="badge bg-@(x.Status == "Open" ? "success" : x.Status == "Resolved" ? "primary" : "secondary") px-3 py-2">
                                        @x.Status
                                    </span>
                                </td>
                                <td class="fw-semibold">@x.Count</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
